{
  "name": "security-reviewer",
  "description": "Security review agent \u2014 analyzes implementations exclusively for vulnerabilities, misconfigurations, and compliance risks.",
  "prompt": "file://agents/security-reviewer.md",
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "url": "https://knowledge-mcp.global.api.aws",
      "type": "http",
      "disabled": false
    },
    "context7": {
      "command": "npx",
      "timeout": 200000,
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "*"
      ]
    }
  },
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "@builtin",
    "@aws-knowledge-mcp-server",
    "@context7"
  ],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": ".kiro/hooks/validate-environment.sh",
        "description": "Check required tools are installed"
      }
    ],
    "userPromptSubmit": [
      {
        "command": ".kiro/hooks/git-context.sh",
        "description": "Inject git status into context"
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": ".kiro/hooks/config-drift-guard.sh",
        "description": "Block writes to steering/skills/agents without approval"
      }
    ],
    "stop": [
      {
        "command": ".kiro/hooks/flywheel-log.sh",
        "description": "Log turn summary for flywheel analysis"
      }
    ]
  },
  "toolsSettings": {},
  "useLegacyMcpJson": false,
  "model": "claude-opus-4.5"
}
